# ============================================================
# Intracodenals — IBM Quantum Credentials
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env  (no subas .env al repo)
# 2. Llena los valores con tus credenciales de IBM Quantum
# 3. Ejecuta: python setup_credentials.py
#
# Obtén tus credenciales en: https://quantum.ibm.com
# Account → API Token
# ============================================================

# Tu Account ID de IBM Quantum (aparece en el dashboard)
IBM_QUANTUM_ACCOUNT_ID=tu_account_id_aqui

# IBM Quantum API Key (token principal)
IBM_QUANTUM_API_KEY=tu_api_key_aqui

# Cloud API Key (si usas IBM Cloud, sino igual que API_KEY)
IBM_QUANTUM_CLOUD_API_KEY=tu_cloud_api_key_aqui

# Password que usarás para encriptar las credenciales localmente
# (inventalo tú, mínimo 8 caracteres, memorízalo)
IBM_QUANTUM_PASSWORD=tu_password_seguro_aqui
